# JitaCart reverse proxy.
#
# - $JC_DOMAIN is the public hostname; Caddy obtains a Let's Encrypt
#   certificate automatically on first start (HTTP-01 over :80).
# - /api/* is rewritten and forwarded to the Rust API; Caddy strips the
#   prefix because the API routes are NOT prefixed with /api.
# - Everything else hits the SvelteKit Node server.
#
# For local docker-compose testing without a real domain, set
# $JC_DOMAIN=:80 and Caddy will serve plain HTTP on port 80 only.

{$JC_DOMAIN} {
    encode zstd gzip

    # Security headers. The CSP is intentionally narrow:
    # - script-src 'self' allows the SvelteKit hydration bundle.
    # - img-src adds images.evetech.net (EVE icons) and data: for inline
    #   SVGs the SvelteKit bundle inlines.
    # - connect-src 'self' covers the api fetches.
    # - frame-ancestors 'none' is a defence-in-depth alongside X-Frame-Options.
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://images.evetech.net; connect-src 'self'; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        # Strip Caddy's own banner so it's not leaked.
        -Server
    }

    @api path /api/*
    handle @api {
        # Strip the /api prefix before forwarding.
        uri strip_prefix /api
        reverse_proxy api:8080 {
            # Forward original client info; api/auth login uses
            # X-Forwarded-For when calling Cloudflare Turnstile.
            header_up X-Real-IP {http.request.remote.host}
            header_up X-Forwarded-For {http.request.remote.host}
        }
    }

    handle {
        reverse_proxy frontend:3000
    }

    log {
        output stdout
        format json
    }
}
