# Env keys map to TOML nesting via figment's `Env::raw().split("__")`:
#   EVE_SSO__CLIENT_ID  -> [eve_sso].client_id
#   ESI__USER_AGENT     -> [esi].user_agent
# Flat top-level keys (DATABASE_URL, TOKEN_ENC_KEY) stay flat.

# --- Postgres (matches docker-compose.yml) ---
DATABASE_URL=postgres://jitacart:jitacart@localhost:5432/jitacart

# --- EVE SSO (Phase 1) ---
# Register your app at https://developers.eveonline.com/applications
EVE_SSO__CLIENT_ID=
EVE_SSO__CLIENT_SECRET=
# Must match the callback URL registered with the EVE app.
EVE_SSO__CALLBACK_URL=http://localhost:8080/auth/eve/callback

# --- Crypto ---
# 32 random bytes, base64. AES-GCM key for refresh-token encryption at rest.
# Generate with:  openssl rand -base64 32
TOKEN_ENC_KEY=

# --- ESI client ---
# Required by CCP. Format: "app-name (contact; +repo_url; eve:CharacterName)"
ESI__USER_AGENT=jitacart-dev (you@example.com; +https://example.com; eve:YourMain)

# --- API server ---
SERVER__BIND=0.0.0.0:8080
RUST_LOG=info,jitacart_api=debug,sqlx=warn
