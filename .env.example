# Env keys map to TOML nesting via figment's `Env::raw().split("__")`:
#   EVE_SSO__CLIENT_ID  -> [eve_sso].client_id
#   ESI__USER_AGENT     -> [esi].user_agent
# Flat top-level keys (DATABASE_URL, TOKEN_ENC_KEY) stay flat.

# --- Postgres ---
# The cluster's bootstrap superuser is `jitacart_bootstrap` (set in
# docker-compose.yml, never in a DATABASE_URL — a superuser bypasses RLS).
# Four named roles do appear in connection strings:
#   jitacart_admin  — owns the schema, runs migrations. RLS does not apply.
#   jitacart_app    — api runtime. NOBYPASSRLS; every query is gated.
#   jitacart_worker — worker runtime. BYPASSRLS; trusted cross-tenant code.
#   jitacart_backup — backup runtime. BYPASSRLS but SELECT-only.
#
# POSTGRES_PASSWORD is the bootstrap superuser's password AND jitacart_admin's
# (init-roles.sh reuses it for admin). APP_/WORKER_/BACKUP_DB_PASSWORD are the
# per-runtime-role passwords.
#
# In prod (docker-compose.yml) the api/worker hostnames resolve to `postgres`
# inside the compose network; override host accordingly:
#   ADMIN_DATABASE_URL=postgres://jitacart_admin:<strong>@postgres:5432/jitacart
#   DATABASE_URL=postgres://jitacart_app:<strong>@postgres:5432/jitacart
ADMIN_DATABASE_URL=postgres://jitacart_admin:jitacart@localhost:5432/jitacart
DATABASE_URL=postgres://jitacart_app:jitacart@localhost:5432/jitacart
POSTGRES_PASSWORD=jitacart
APP_DB_PASSWORD=jitacart
WORKER_DB_PASSWORD=jitacart
BACKUP_DB_PASSWORD=jitacart

# --- EVE SSO (Phase 1) ---
# Register your app at https://developers.eveonline.com/applications
EVE_SSO__CLIENT_ID=
EVE_SSO__CLIENT_SECRET=
# Must match the callback URL registered with the EVE app.
EVE_SSO__CALLBACK_URL=http://localhost:8080/auth/eve/callback

# --- Token-at-rest encryption (Phase 9 / M2) ---
# EITHER (legacy single-key, kid='v1'):
#   openssl rand -base64 32
TOKEN_ENC_KEY=
#
# OR (multi-key, supports rotation; takes precedence over TOKEN_ENC_KEY):
#   TOKEN_ENC__PRIMARY=v2
#   TOKEN_ENC__KEYS__V1=<base64-32-bytes>
#   TOKEN_ENC__KEYS__V2=<base64-32-bytes>

# --- ESI client ---
# Required by CCP. Format: "app-name (contact; +repo_url; eve:CharacterName)"
ESI__USER_AGENT=jitacart-dev (you@example.com; +https://example.com; eve:YourMain)

# --- API server ---
SERVER__BIND=0.0.0.0:8080
RUST_LOG=info,jitacart_api=debug,sqlx=warn

# --- Worker server ---
# Loopback-only by default. The api/uptime probe reaches this via docker
# DNS on the `worker` service name (still on its in-container loopback).
# /metrics is mounted on the same listener.
WORKER__HEALTHZ_BIND=127.0.0.1:9091

# --- Metrics ---
# Prometheus exposition for the api. Loopback only by default — there
# is no auth, an unforgeable bind is the security boundary. Set to
# empty to disable. Scrape with `docker compose exec api curl
# 127.0.0.1:9090/metrics` or via a sidecar in the same network namespace.
METRICS__BIND=127.0.0.1:9090

# --- Rate limits (Phase 9 / M3) ---
# RATE_LIMIT__DISABLED=false
# RATE_LIMIT__PER_IP_BURST=30
# RATE_LIMIT__PER_IP_PERIOD_SECS=1
# RATE_LIMIT__AUTH_BURST=5
# RATE_LIMIT__AUTH_PERIOD_SECS=10

# --- Abuse caps (Phase 9 / M3) ---
# LIMITS__GROUPS_PER_USER=10
# LIMITS__LISTS_PER_GROUP=200
# LIMITS__ITEMS_PER_LIST=500
# LIMITS__CHARACTERS_PER_USER=12

# --- Cloudflare Turnstile (Phase 9 / M3) ---
# Set DISABLED=true for local dev (default). For prod, register a site
# at https://dash.cloudflare.com/?to=/:account/turnstile and set both keys.
TURNSTILE__DISABLED=true
TURNSTILE__SITE_KEY=
TURNSTILE__SECRET_KEY=

# --- Logging (Phase 9 / M6) ---
# `json` for structured one-object-per-line output (recommended in prod);
# anything else gets the human-readable fmt layer.
JC_LOG_FORMAT=json

# --- Backups (Phase 9 / M6) ---
# The `backup` service runs by default in docker-compose.yml. The four
# vars below are REQUIRED for production — without BACKUP_AGE_RECIPIENT
# or BACKUP_RCLONE_REMOTE the container parks (Up + one WARN log line)
# and no backups are taken. See backup/RESTORE.md for the full setup
# and restore drill.
#
# Generate the age key on a trusted machine (NOT the prod host — the
# private key only needs to exist where you'd restore):
#   age-keygen -o jitacart-backup.age
# The `# public key:` line goes into BACKUP_AGE_RECIPIENT. The private
# key stays OFFLINE.
BACKUP_AGE_RECIPIENT=
# rclone remote + path, e.g. `b2:my-bucket/jitacart`. See
# backup/rclone.conf.example for provider config.
BACKUP_RCLONE_REMOTE=
# Daily backups retained before pruning. Set your bucket lifecycle
# policy to at least RETAIN+5 days; this is the floor, not the ceiling.
BACKUP_RETAIN_DAILY=30
# Hour of UTC day to fire (0-23). Default 03:00 UTC.
BACKUP_HOUR_UTC=3
# Smoke-test toggle. Default false so a container restart during an
# incident doesn't produce a duplicate same-day backup. Set to true
# for first-deploy verification, then unset.
# BACKUP_RUN_ON_START=false

# --- Prod images (docker-compose.yml) ---
# Owner of the GHCR org/user that hosts the published images. The
# version + digest of each image is hardcoded in docker-compose.yml
# (rewritten via scripts/bump-image-digests.sh per release) — there's
# no JC_IMAGE_TAG knob anymore, because mutable tags defeat the
# audit-trail and `git revert` rollback story.
JC_IMAGE_OWNER=eyedeekay

# --- Caddy / TLS (docker-compose.yml only) ---
# The public hostname Caddy serves on. Use ":80" for local HTTP-only
# testing; use the real FQDN (e.g. "jitacart.example.com") in prod and
# Caddy will obtain a Let's Encrypt cert automatically.
JC_DOMAIN=:80
# Email passed to ACME for Let's Encrypt. Required when JC_DOMAIN is a
# real hostname; ignored for ":80".
JC_ACME_EMAIL=
