# Staging env template. Copy to .env.staging and fill it in:
#     cp .env.staging.example .env.staging
#
# Used only by docker-compose.staging.yml — the full five-service stack
# running mutable `:latest` images, co-located on the same host as prod.
# Same keys as .env.example with staging-appropriate defaults; see
# .env.example for the full per-key prose.
#
# A real .env.staging is gitignored AND refused by CI's secret-scan.

# --- Postgres ---
# Staging shares the host with prod but NOT the secrets — give it its
# own passwords. The compose file composes the runtime DSNs from these.
ADMIN_DATABASE_URL=postgres://jitacart_admin:CHANGE_ME_STAGING@postgres:5432/jitacart
DATABASE_URL=postgres://jitacart_app:CHANGE_ME_STAGING_APP@postgres:5432/jitacart
POSTGRES_PASSWORD=CHANGE_ME_STAGING
APP_DB_PASSWORD=CHANGE_ME_STAGING_APP
WORKER_DB_PASSWORD=CHANGE_ME_STAGING_WORKER
BACKUP_DB_PASSWORD=CHANGE_ME_STAGING_BACKUP

# --- EVE SSO ---
# Register your app at https://developers.eveonline.com/applications.
# Use a staging EVE app — never reuse prod's client id/secret. See
# DEPLOY.md § EVE SSO callback URLs for the dev/staging/prod matrix.
EVE_SSO__CLIENT_ID=
EVE_SSO__CLIENT_SECRET=
# Must match a callback URL registered with the EVE app. The value
# depends on whether you front staging with TLS (see the Caddy / TLS
# block at the bottom of this file):
#   - TLS via prod Caddy:  https://staging.<domain>/auth/eve/callback
#   - HTTP-only smoke test: http://<staging-host>:8080/auth/eve/callback
EVE_SSO__CALLBACK_URL=https://staging.jitacart.example.com/auth/eve/callback

# --- Token-at-rest encryption ---
#   openssl rand -base64 32
TOKEN_ENC_KEY=

# --- ESI client ---
# Required by CCP. Format: "app-name (contact; +repo_url; eve:CharacterName)"
ESI__USER_AGENT=jitacart-staging (you@example.com; +https://example.com; eve:YourMain)

# --- API server ---
SERVER__BIND=0.0.0.0:8080
RUST_LOG=info,jitacart_api=debug,sqlx=warn

# --- Worker server ---
WORKER__HEALTHZ_BIND=127.0.0.1:9091

# --- Metrics ---
METRICS__BIND=127.0.0.1:9090

# --- Cloudflare Turnstile ---
# Staging skips the captcha — no need to register a Turnstile site.
TURNSTILE__DISABLED=true
TURNSTILE__SITE_KEY=
TURNSTILE__SECRET_KEY=

# --- Logging ---
JC_LOG_FORMAT=json

# --- Images (docker-compose.staging.yml) ---
# Owner of the GHCR org/user that hosts the published images. Staging
# pulls the mutable `:latest` tag (no digest pin) — that's the point.
JC_IMAGE_OWNER=idknerdyshit

# --- Caddy / TLS (docker-compose.staging.yml only) ---
# Staging's own Caddy is HTTP-only: its host ports are remapped to
# 8080/8443 (prod owns 80/443), so it cannot run ACME HTTP-01 itself —
# keep JC_DOMAIN=:80 here regardless.
#
# For real TLS, front staging with a `staging.<domain>` vhost on the
# PROD Caddy: copy caddy/conf.d/staging.caddy.example to
# caddy/conf.d/staging.caddy, set the hostname, and `docker compose up
# -d caddy` on the prod stack. The prod Caddy terminates TLS and
# reverse-proxies to this stack over JC_STAGING_HTTP_PORT. See
# DEPLOY.md § Staging environment → TLS via the prod Caddy.
JC_DOMAIN=:80
JC_ACME_EMAIL=

# --- Staging Caddy host ports (docker-compose.staging.yml only) ---
# Remapped off 80/443 because prod owns those on the shared host. The
# prod Caddy's staging vhost reverse-proxies to JC_STAGING_HTTP_PORT.
JC_STAGING_HTTP_PORT=8080
JC_STAGING_HTTPS_PORT=8443
